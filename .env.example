# Copy this file to .env and fill in your local values.
# Never commit .env or real API credentials.

# TMDB credentials. A v4 Read Access Token is preferred; v3 API key is a fallback.
TMDB_BEARER_TOKEN=
TMDB_API_KEY=

# Public website name shown in page titles, metadata, logo alt text, and sharing.
SITE_NAME=StreamHIVE

# Player provider
# Built-in presets: multiembed, vidsrc-to, vidsrc-cc, embed-su
PLAYER_PROVIDER=multiembed

# Optional custom player URL templates.
# Leave blank to use the selected PLAYER_PROVIDER preset.
# Available placeholders:
# {video_id}   TMDB ID when available, otherwise IMDb ID
# {tmdb_id}    TMDB ID only
# {imdb_id}    IMDb ID only
# {tmdb_flag}  1 when {video_id} is TMDB, 0 when it is IMDb
# {season}     Episode season number
# {episode}    Episode number
PLAYER_MOVIE_URL=
PLAYER_EPISODE_URL=
