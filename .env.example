# Copy this file to .env and fill in your local values.
# Never commit .env or real API credentials.

# TMDB credentials. A v4 Read Access Token is preferred; v3 API key is a fallback.
TMDB_BEARER_TOKEN=
TMDB_API_KEY=

# Application mode.
APP_ENV=local
APP_DEBUG=true

# Public website name shown in page titles, metadata, logo alt text, and sharing.
SITE_NAME=StreamHIVE

# Player provider
# Built-in presets: multiembed, vidsrc-to, vidsrc-cc, embed-su
PLAYER_PROVIDER=multiembed

# Optional custom player URL templates.
# Leave blank to use the selected PLAYER_PROVIDER preset.
# Available placeholders:
# {video_id}   TMDB ID when available, otherwise IMDb ID
# {tmdb_id}    TMDB ID only
# {imdb_id}    IMDb ID only
# {tmdb_flag}  1 when {video_id} is TMDB, 0 when it is IMDb
# {season}     Episode season number
# {episode}    Episode number
PLAYER_MOVIE_URL=
PLAYER_EPISODE_URL=

# Common examples:
# MultiEmbed
# PLAYER_PROVIDER=multiembed
# PLAYER_MOVIE_URL=https://multiembed.mov/?video_id={video_id}&tmdb={tmdb_flag}
# PLAYER_EPISODE_URL=https://multiembed.mov/?video_id={video_id}&tmdb={tmdb_flag}&s={season}&e={episode}

# VidSrc.to
# PLAYER_PROVIDER=vidsrc-to
# PLAYER_MOVIE_URL=https://vidsrc.to/embed/movie/{tmdb_id}
# PLAYER_EPISODE_URL=https://vidsrc.to/embed/tv/{tmdb_id}/{season}/{episode}

# VidSrc.cc
# PLAYER_PROVIDER=vidsrc-cc
# PLAYER_MOVIE_URL=https://vidsrc.cc/v2/embed/movie/{tmdb_id}
# PLAYER_EPISODE_URL=https://vidsrc.cc/v2/embed/tv/{tmdb_id}/{season}/{episode}

# Embed.su
# PLAYER_PROVIDER=embed-su
# PLAYER_MOVIE_URL=https://embed.su/embed/movie/{tmdb_id}
# PLAYER_EPISODE_URL=https://embed.su/embed/tv/{tmdb_id}/{season}/{episode}
